# gitlab-register 配置模板
# 复制为 .env 后按需修改。未填写的项目会使用程序默认值。

# 邮箱服务
EMAIL_PROVIDER=idatariver
IDATARIVER_API_KEY=
IDATARIVER_API_BASE=https://apiok.us/api/cbea
IDATARIVER_POLL_INTERVAL_SECONDS=5
NIMAIL_API_BASE=https://www.nimail.cn

# 运行目标
COUNT=1

# 输出批次
RUN_LABEL=
OUTPUT_ROOT=registration_results
OUTPUT_DIR=

# 浏览器和日志
HEADLESS=1
SCREENSHOTS=0
LOG_VERBOSE=0

# 代理给邮箱 API 使用
HTTP_PROXY=
HTTPS_PROXY=
